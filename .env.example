# Conexão com o banco de dados MySQL
DATABASE_URL="mysql://usuario:senha@localhost:3306/gorila_rise"

# Chave secreta para assinar tokens JWT
JWT_SECRET="troque-por-uma-chave-forte"

# Porta em que a API vai escutar
PORT=3333

# Dados do usuário administrador criado no seed inicial
ADMIN_NOME="Administrador"
