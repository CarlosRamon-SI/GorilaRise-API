generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         Int      @id @default(autoincrement())
  nome       String
  email      String   @unique
  cpf        String   @unique
  telefone   String
  nascimento DateTime
  endereco   String
  cidade     String
  cep        String
  senha      String
  role       Role     @default(USUARIO)
  ativo      Boolean  @default(true)
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  matriculas Matricula[]
  checkIns   CheckIn[]
  anamnese   Anamnese?
  recordes   Recorde[]
}

model Modalidade {
  id        Int        @id @default(autoincrement())
  nome      String
  descricao String     @db.Text
  categoria String
  ativa     Boolean    @default(true)

  matriculas Matricula[]
  checkIns   CheckIn[]
  anamnese   Anamnese?
  recordes   Recorde[]
}

model Plano {
  id        Int        @id @default(autoincrement())
  nome      String
  valor     Decimal    @db.Decimal(10, 2)
  descricao String?
  ativo     Boolean    @default(true)

  matriculas Matricula[]
  checkIns   CheckIn[]
  anamnese   Anamnese?
  recordes   Recorde[]
}

model Matricula {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  modalidadeId Int
  planoId     Int
  status      StatusMatricula @default(ATIVA)
  criadoEm   DateTime @default(now())

  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  modalidade Modalidade @relation(fields: [modalidadeId], references: [id])
  plano      Plano      @relation(fields: [planoId], references: [id])
}

model ProjetoSocial {
  id         Int      @id @default(autoincrement())
  titulo     String
  slug       String   @unique
  subtitulo  String?
  descricao  String   @db.Text
  conteudo   String?  @db.Text
  imagemUrl  String?
  icone      String   @default("heart")
  ativo      Boolean  @default(true)
  criadoEm  DateTime @default(now())
}

model DocumentoOficial {
  id        Int      @id @default(autoincrement())
  titulo    String
  descricao String?
  fileUrl   String
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now())
}

model Lead {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String
  whatsapp  String?
  origem    String   @default("eventos")
  criadoEm DateTime @default(now())
}

enum Role {
  USUARIO
  TREINADOR
  ADMIN
}

enum StatusMatricula {
  ATIVA
  INATIVA
  PENDENTE
}

model Configuracao {
  id          Int    @id @default(autoincrement())
  logradouro  String @default("")
  numero      String @default("")
  complemento String @default("")
  bairro      String @default("")
  cidade      String @default("")
  estado      String @default("")
  cep         String @default("")
  telefone    String @default("")
  whatsapp    String @default("")
  email       String @default("")
  horarios    Json   @default("{}")
  instagram   String @default("")
  facebook    String @default("")
  youtube     String @default("")
  tiktok      String @default("")
}

model Turma {
  id         Int       @id @default(autoincrement())
  codigo     String    @unique
  horario    String
  dias       Json
  tipo       String    @default("regular")
  descricao  String?
  faixaIdade String?
  capacidade Int       @default(6)
  ativa      Boolean   @default(true)
  checkIns   CheckIn[]
}

model CheckIn {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  turmaId   Int
  data      DateTime @db.Date
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  turma     Turma    @relation(fields: [turmaId], references: [id])

  @@unique([usuarioId, turmaId, data])
}

model Anamnese {
  id                    Int       @id @default(autoincrement())
  usuarioId             Int       @unique
  profissao             String?
  contatoEmergenciaNome String?
  contatoEmergenciaTel  String?
  objetivos             Json      @default("[]")
  doencas               String?   @db.Text
  medicamentos          String?   @db.Text
  cirurgias             String?   @db.Text
  problemasArticulares  String?   @db.Text
  historicoCardio       Boolean   @default(false)
  fumante               Boolean   @default(false)
  frequenciaBanheiro    String?
  atividadeAnterior     String?   @db.Text
  frequenciaSemanal     Int?
  qualidadeSono         String?
  consumoAlcool         String?
  termoAssinado         Boolean   @default(false)
  termoData             DateTime?
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt

  usuario               Usuario   @relation(fields: [usuarioId], references: [id])
}

model Recorde {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  exercicio String
  carga     Float
  data      DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}
