generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           Int           @id @default(autoincrement())
  nome         String
  email        String        @unique
  cpf          String        @unique
  telefone     String
  nascimento   DateTime
  endereco     String
  cidade       String
  cep          String
  senha        String
  role         Role          @default(USUARIO)
  ativo        Boolean       @default(true)
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  matriculas    Matricula[]
  checkIns      CheckIn[]
  anamnese      Anamnese?
  recordes      Recorde[]
  fotosProgresso FotoProgresso[]
  biometria     Biometria?
  prontuarioDocs ProntuarioDoc[]
}

model Modalidade {
  id        Int         @id @default(autoincrement())
  nome      String
  descricao String      @db.Text
  categoria String
  ativa     Boolean     @default(true)

  matriculas Matricula[]
}

model Plano {
  id        Int         @id @default(autoincrement())
  nome      String
  valor     Decimal     @db.Decimal(10, 2)
  descricao String?
  ativo     Boolean     @default(true)

  matriculas Matricula[]
}

model Matricula {
  id           Int             @id @default(autoincrement())
  usuarioId    Int
  modalidadeId Int
  planoId      Int
  status       StatusMatricula @default(ATIVA)
  criadoEm     DateTime        @default(now())

  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  modalidade Modalidade @relation(fields: [modalidadeId], references: [id])
  plano      Plano      @relation(fields: [planoId], references: [id])
}

model ProjetoSocial {
  id        Int      @id @default(autoincrement())
  titulo    String
  slug      String   @unique
  subtitulo String?
  descricao String   @db.Text
  conteudo  String?  @db.Text
  imagemUrl String?
  icone     String   @default("heart")
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
}

model DocumentoOficial {
  id        Int      @id @default(autoincrement())
  titulo    String
  descricao String?
  fileUrl   String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
}

model Lead {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String
  whatsapp  String?
  origem    String   @default("eventos")
  criadoEm  DateTime @default(now())
}

enum Role {
  USUARIO
  TREINADOR
  ADMIN
  PROFESSOR
  NUTRICIONISTA
  SOCIO_TORCEDOR
}

enum StatusMatricula {
  ATIVA
  INATIVA
  PENDENTE
}

enum FuncaoFuncionario {
  PROFESSOR
  NUTRICIONISTA
  FISIOTERAPEUTA
}

enum CategoriaPatrocinador {
  PLATINA
  OURO
  PRATA
  BRONZE
}

enum TipoNotificacao {
  AVISO
  EVENTO
  COMUNICADO
}

model Premiacao {
  id          Int       @id @default(autoincrement())
  titulo      String
  descricao   String?   @db.Text
  atletaNome  String    @default("")
  data        DateTime? @db.Date
  imagemUrl   String?
  ativo       Boolean   @default(true)
  criadoEm    DateTime  @default(now())
}

model Patrocinador {
  id        Int                   @id @default(autoincrement())
  nome      String
  descricao String?               @db.Text
  logoUrl   String?
  link      String?
  categoria CategoriaPatrocinador @default(OURO)
  ativo     Boolean               @default(true)
  criadoEm  DateTime              @default(now())
}

model Notificacao {
  id        Int             @id @default(autoincrement())
  titulo    String
  corpo     String          @db.Text
  tipo      TipoNotificacao @default(AVISO)
  criadoEm  DateTime        @default(now())
}

model Configuracao {
  id          Int    @id @default(autoincrement())
  logradouro  String @default("")
  numero      String @default("")
  complemento String @default("")
  bairro      String @default("")
  cidade      String @default("")
  estado      String @default("")
  cep         String @default("")
  telefone    String @default("")
  whatsapp    String @default("")
  email       String @default("")
  horarios    Json   @default("{}")
  instagram   String @default("")
  facebook    String @default("")
  youtube     String @default("")
  tiktok      String @default("")
}

model Funcionario {
  id        Int               @id @default(autoincrement())
  nome      String
  email     String            @unique
  cref      String            @default("")
  funcao    FuncaoFuncionario @default(PROFESSOR)
  ativo     Boolean           @default(true)
  criadoEm  DateTime          @default(now())
}

model Turma {
  id         Int       @id @default(autoincrement())
  codigo     String    @unique
  horario    String
  dias       Json
  tipo       String    @default("regular")
  descricao  String?
  faixaIdade String?
  capacidade Int       @default(6)
  ativa      Boolean   @default(true)
  checkIns   CheckIn[]
}

model CheckIn {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  turmaId   Int
  data      DateTime @db.Date
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  turma     Turma    @relation(fields: [turmaId], references: [id])

  @@unique([usuarioId, turmaId, data])
}

model Anamnese {
  id                    Int       @id @default(autoincrement())
  usuarioId             Int       @unique
  profissao             String?
  contatoEmergenciaNome String?
  contatoEmergenciaTel  String?
  objetivos             Json      @default("[]")
  doencas               String?   @db.Text
  medicamentos          String?   @db.Text
  cirurgias             String?   @db.Text
  problemasArticulares  String?   @db.Text
  historicoCardio       Boolean   @default(false)
  fumante               Boolean   @default(false)
  frequenciaBanheiro    String?
  atividadeAnterior     String?   @db.Text
  frequenciaSemanal     String?
  qualidadeSono         String?
  consumoAlcool         String?
  termoAssinado         Boolean   @default(false)
  termoData             DateTime?
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt

  usuario               Usuario   @relation(fields: [usuarioId], references: [id])
}

model Recorde {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  exercicio String
  carga     String
  data      DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}

enum TipoFoto {
  INICIAL
  PROGRESSO
}

model FotoProgresso {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  tipo      TipoFoto
  url       String
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}

model Biometria {
  id              Int      @id @default(autoincrement())
  usuarioId       Int      @unique
  peso            String?
  altura          String?
  pressaoArterial String?
  bioimpedancia   String?
  atualizadoEm    DateTime @updatedAt

  usuario         Usuario  @relation(fields: [usuarioId], references: [id])
}

model ProntuarioDoc {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  nome      String
  url       String
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}

model WOD {
  id         Int      @id @default(autoincrement())
  titulo     String
  descricao  String?
  exercicios String?  @db.Text
  data       DateTime @db.Date
  criadoEm   DateTime @default(now())
}

model TreinoPrescrito {
  id         Int      @id @default(autoincrement())
  atletaNome String
  titulo     String
  exercicios String?  @db.Text
  criadoEm   DateTime @default(now())
}
